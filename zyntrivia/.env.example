# All variables optional in development — every integration degrades gracefully.

# Supabase Postgres (REST). Leads fall back to .leads.local.json when unset.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend). Skipped when unset.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=

# Upstash rate limiting. In-memory fallback when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lead intake workflow webhook. Skipped when unset.
N8N_WEBHOOK_URL=

# Cal.com embed on the quote form.
NEXT_PUBLIC_CAL_LINK=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Canonical site URL for metadata/sitemap
NEXT_PUBLIC_SITE_URL=https://zyntrivia.com
